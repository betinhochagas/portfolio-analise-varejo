# Copie para  orchestration/.env  e ajuste os valores.
# O docker-compose le este arquivo automaticamente.

# UID do processo Airflow (Linux/Mac use o seu `id -u`; no Windows deixe 50000)
AIRFLOW_UID=50000

# ID do seu projeto no Google Cloud (mesmo da Fase 1)
GCP_PROJECT_ID=seu-projeto-id

# Caminho do arquivo de credencial ADC no HOST (gerado por
# `gcloud auth application-default login`).
#   Windows: C:/Users/<voce>/AppData/Roaming/gcloud/application_default_credentials.json
#   Linux/Mac: /home/<voce>/.config/gcloud/application_default_credentials.json
GCP_ADC_PATH=C:/Users/rober/AppData/Roaming/gcloud/application_default_credentials.json
